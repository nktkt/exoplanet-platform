# =============================================================================
# Exoplanet Analysis Platform - environment configuration
# -----------------------------------------------------------------------------
# All variables are optional; the defaults in `exoplanet_platform/config.py`
# apply when a variable is unset. Copy this file to `.env` and edit as needed.
#
# Nested settings use a double-underscore delimiter, so for example the setting
# `Settings.storage.database_url` is controlled by `EXOPLANET_STORAGE__DATABASE_URL`.
# =============================================================================

# ---- Global ---------------------------------------------------------------
# EXOPLANET_ENVIRONMENT=development       # development | staging | production
# EXOPLANET_LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
# EXOPLANET_LOG_JSON=false                # emit structured JSON log lines
# EXOPLANET_DATA_DIR=./data               # local directory for CSV/scratch files

# ---- Storage (database) ---------------------------------------------------
# EXOPLANET_STORAGE__DATABASE_URL=sqlite:///./exoplanet.db
# EXOPLANET_STORAGE__DATABASE_URL=postgresql+psycopg2://exoplanet:exoplanet@localhost:5432/exoplanet
# EXOPLANET_STORAGE__ECHO_SQL=false
# EXOPLANET_STORAGE__POOL_SIZE=10
# EXOPLANET_STORAGE__MAX_OVERFLOW=20

# ---- API server ------------------------------------------------------------
# EXOPLANET_API__HOST=0.0.0.0
# EXOPLANET_API__PORT=8000
# EXOPLANET_API__CORS_ORIGINS=["*"]
# EXOPLANET_API__REQUEST_TIMEOUT_SECONDS=120
# EXOPLANET_API__RATE_LIMIT_PER_MINUTE=120

# Optional API key. If set, all write endpoints require header X-API-Key.
# EXOPLANET_API_KEY=change-me

# ---- Data sources ---------------------------------------------------------
# EXOPLANET_DATA_SOURCES__NASA_EXOPLANET_ARCHIVE_URL=https://exoplanetarchive.ipac.caltech.edu/TAP/sync
# EXOPLANET_DATA_SOURCES__MAST_URL=https://mast.stsci.edu/api/v0.1
# EXOPLANET_DATA_SOURCES__JPL_HORIZONS_URL=https://ssd.jpl.nasa.gov/api/horizons.api
# EXOPLANET_DATA_SOURCES__GAIA_TAP_URL=https://gea.esac.esa.int/tap-server/tap
# EXOPLANET_DATA_SOURCES__HTTP_TIMEOUT_SECONDS=60
# EXOPLANET_DATA_SOURCES__HTTP_MAX_RETRIES=4
# EXOPLANET_DATA_SOURCES__HTTP_RETRY_BACKOFF_SECONDS=2
# EXOPLANET_DATA_SOURCES__CACHE_TTL_SECONDS=86400
# EXOPLANET_DATA_SOURCES__CACHE_MAX_ENTRIES=10000

# ---- Analysis tuning ------------------------------------------------------
# EXOPLANET_ANALYSIS__BLS_MIN_PERIOD_DAYS=0.5
# EXOPLANET_ANALYSIS__BLS_MAX_PERIOD_DAYS=100.0
# EXOPLANET_ANALYSIS__BLS_FREQUENCY_FACTOR=5.0
# EXOPLANET_ANALYSIS__DETREND_WINDOW_HOURS=12.0
# EXOPLANET_ANALYSIS__SIGMA_CLIP=5.0
